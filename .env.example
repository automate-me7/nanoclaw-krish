# Assistant Identity
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Anthropic
ANTHROPIC_API_KEY=YOUR_API_KEY

# Container Settings
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# Timezone
TZ=Asia/Kolkata

# Smart Polling (disabled by default)
SMART_POLLING_ENABLED=false

# ChromaDB / Tier 4 Memory (disabled by default)
CHROMA_ENABLED=false
CHROMA_HOST=http://localhost
CHROMA_PORT=8000

# Senri CRM (optional — set both to enable Senri tools)
SENRI_API_KEY=
SENRI_API_SECRET=

# Microsoft 365 — Teams, Outlook, SharePoint (optional)
# Set to 'true' on the Mac Mini where the MS365 MCP HTTP server is running.
# Leave unset or 'false' on dev machines.
MS365_ENABLED=false
